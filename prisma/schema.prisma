// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model SecurityConfig {
  id             String   @id @default(cuid())
  passwordHash   String
  protectedUrl   String
  accessLifetime Int      @default(20)
  accessWindow   Int      @default(5)
  isActive       Boolean  @default(true)
  maxDevices     Int      @default(3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AccessToken {
  id          String    @id @default(cuid())
  token       String    @unique
  userName    String
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  isValidated Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([userName])
  @@index([token])
  @@index([isValidated])
}

model AccessLog {
  id        String   @id @default(cuid())
  action    String
  userName  String?
  ipAddress String?
  userAgent String?
  details   String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([userName])
  @@index([createdAt])
}
